# Server Configuration
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=*

# OpenRouter LLM Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=x-ai/grok-4.1-fast
APP_NAME=Iris

# LLM Settings
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.7
MAX_CONVERSATION_HISTORY=20

# ElevenLabs Configuration (Optional - only needed if using ElevenLabs for TTS/STT)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_NAME=Hope
ELEVENLABS_VOICE_ID=your_voice_id_here
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# ElevenLabs Voice Settings
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY=0.75
ELEVENLABS_STYLE=0

# Enable/Disable STT and TTS
ENABLE_STT=true
ENABLE_TTS=true

# TTS/STT Provider (elevenlabs or local)
# 'local' uses self-hosted services, 'elevenlabs' uses ElevenLabs API
TTS_PROVIDER=local
STT_PROVIDER=local

# Local TTS/STT Service Configuration
# Point to your local TTS/STT server (e.g., using Edge-TTS or Whisper)
LOCAL_TTS_URL=http://localhost:5000
EDGE_VOICE=en-US-AvaNeural
WHISPER_MODEL=base

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=iris_user
MYSQL_PASSWORD=your_database_password_here
MYSQL_DATABASE=iris_ai

# Tool/Function Calling Configuration
ENABLE_TOOLS=true
MEDIA_DASHBOARD_URL=http://localhost:3000
MEDIA_DASHBOARD_API_KEY=your_media_dashboard_api_key_here

# ComfyUI/Stable Diffusion Configuration
# Point to your local ComfyUI installation for image generation
COMFYUI_URL=http://127.0.0.1:8188
IMAGE_OUTPUT_DIR=./output/images
